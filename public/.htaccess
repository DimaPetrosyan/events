# SPA/статик-фолбэк для React Router на Apache (shared-хостинг).
# Если запрошенного файла/папки нет — отдаём index.html,
# дальше маршрут разбирает React Router на клиенте.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Адреса проектов сменились вместе с названиями. 301 со старых на новые,
  # чтобы старые ссылки и выдача поисковиков не отдавали 404.
  RewriteRule ^project/zimnyaya-skazka/?$ /project/hrustalnoe-serdce [R=301,L]
  RewriteRule ^project/evangelina/?$      /project/den-rozhdeniya-evy [R=301,L]
  RewriteRule ^project/vypusknoy/?$       /project/vypusknoy-prezident [R=301,L]
  RewriteRule ^project/alya-rus/?$        /project/russkaya-skazka [R=301,L]
  RewriteRule ^project/novyy-god-lkp/?$   /project/novogodniy-vecher-lkp [R=301,L]
  RewriteRule ^project/lesnaya-skazka/?$  /project/magiya-v-lesu [R=301,L]
  RewriteRule ^project/nasha-svadba/?$    /project/on-ona-dozhd [R=301,L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Кэширование статики (ассеты с хешем в имени — можно кэшировать надолго)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
